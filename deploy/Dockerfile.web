# Dockerfile.web  → builds and runs the Next.js web app (apps/web)

FROM node:22-alpine

WORKDIR /app

# System deps
RUN apk add --no-cache libc6-compat openssl

# Install dependencies using workspaces
COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/
COPY packages/database/package.json packages/database/
COPY packages/types/package.json packages/types/
RUN npm install

# Copy full monorepo
COPY . .

# Set env vars BEFORE build (Next.js needs NEXT_PUBLIC_* at build time)
ENV NODE_ENV=production
ENV APP_ENV=production
ENV NEXT_PUBLIC_APP_ENV=production
ENV NEXT_PUBLIC_APP_URL=http://localhost:3000
ENV NEXT_PUBLIC_MAILOPS_API_URL=http://localhost:3001/api

# Create minimal env file for next.config.ts
RUN mkdir -p apps/web/env && cp apps/web/env/.env.example apps/web/env/.env.production

# Generate Prisma client (no DB connection needed)
RUN npm run db:generate --workspace=packages/database

# Build the web app (override script's APP_ENV=development)
RUN APP_ENV=production npm run build:prod --workspace=apps/web

EXPOSE 3000

# Start Next.js web app
CMD ["npm", "run", "start", "--workspace=apps/web"]
