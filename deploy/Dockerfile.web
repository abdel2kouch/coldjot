# Dockerfile.web  → builds and runs the Next.js web app (apps/web)

FROM node:22-alpine

WORKDIR /app

# System deps
RUN apk add --no-cache libc6-compat openssl

# Install dependencies using workspaces
COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/
COPY packages/database/package.json packages/database/
COPY packages/types/package.json packages/types/
RUN npm install

# Copy full monorepo
COPY . .

# Set env vars BEFORE build (Next.js needs NEXT_PUBLIC_* at build time)
ENV NODE_ENV=production
ENV APP_ENV=production
ENV NEXT_PUBLIC_APP_ENV=production
ENV NEXT_PUBLIC_APP_URL=http://localhost:3000
ENV NEXT_PUBLIC_MAILOPS_API_URL=http://localhost:3001/api

# Provide required env vars for Zod validation during build (env.ts)
ENV GOOGLE_CLIENT_ID=placeholder
ENV GOOGLE_CLIENT_SECRET=placeholder
ENV GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback/google
ENV GOOGLE_CLIENT_ID_EMAIL=placeholder
ENV GOOGLE_CLIENT_SECRET_EMAIL=placeholder
ENV GOOGLE_REDIRECT_URI_EMAIL=http://localhost:3000/api/mailboxes/gmail/callback
ENV NEXTAUTH_SECRET=build-time-placeholder
ENV DATABASE_URL=postgresql://placeholder:placeholder@localhost:5432/placeholder

# Create minimal env file for next.config.ts
RUN mkdir -p apps/web/env && cp apps/web/env/.env.example apps/web/env/.env.production

# Generate Prisma client (no DB connection needed)
RUN npm run db:generate --workspace=packages/database

# Build shared packages first (types needs tsup to produce dist/)
RUN npm run build --workspace=packages/types

# Build the web app
RUN APP_ENV=production npm run build:prod --workspace=apps/web

# Clear build-time placeholders (runtime env vars from Dokploy will override)
ENV GOOGLE_CLIENT_ID=
ENV GOOGLE_CLIENT_SECRET=
ENV GOOGLE_REDIRECT_URI=
ENV GOOGLE_CLIENT_ID_EMAIL=
ENV GOOGLE_CLIENT_SECRET_EMAIL=
ENV GOOGLE_REDIRECT_URI_EMAIL=
ENV NEXTAUTH_SECRET=
ENV DATABASE_URL=

EXPOSE 3000

# Start Next.js web app
CMD ["npm", "run", "start", "--workspace=apps/web"]
